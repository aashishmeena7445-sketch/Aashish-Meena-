def add_numbers(a, b):
    return a + b
while True:
    num1 = int(input("enter first number"))
    num2 = int(input("enter second number"))
    result = add_numbers(num1, num2)
    print("Sum =", result)
    choice = input("Do you want to add more numbers?(yes/no): ")
    if choice.lower() !="yes":
        break
